import numpy as np

def factorial(n: int) -> int:
    if n <= 1:
        return 1
    
    def matrix_mult(A, B):
        return [[sum(x * y for x, y in zip(row, col)) for col in zip(*B)] for row in A]

    def matrix_exponentiate(matrix, power):
        result = [[1 if i == j else 0 for j in range(len(matrix))] for i in range(len(matrix))]
        base = matrix
        while power:
            if power % 2 == 1:
                result = matrix_mult(result, base)
            base = matrix_mult(base, base)
            power //= 2
        return result

    matrix_size = n + 1
    trans_matrix = [[0] * matrix_size for _ in range(matrix_size)]
    for i in range(1, matrix_size):
        trans_matrix[i][i-1] = 1
    for j in range(matrix_size):
        trans_matrix[0][j] = j
    
    result_matrix = matrix_exponentiate(trans_matrix, n - 1)
    return result_matrix[0][0]
