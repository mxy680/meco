def factorial(n: int) -> int:
    def factorial_range(start: int, end: int) -> int:
        if start > end:
            return 1
        if start == end:
            return start
        mid = (start + end) // 2
        return factorial_range(start, mid) * factorial_range(mid + 1, end)
    if n == 0:
        return 1
    return factorial_range(1, n)
