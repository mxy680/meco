from math import pi, e

def factorial(n: int) -> int:
    if n == 0:
        return 1
    approximation = (n / e) ** n * (2 * pi * n) ** 0.5
    correction = 1
    for i in range(1, 6):
        correction += ((-1)**i) * (1/(i * (2**i))) / (n**i)
    return int(round(approximation * correction))
