def factorial(n: int) -> int:
    cache = {0: 1}

    def compute_factorial(k: int) -> int:
        if k not in cache:
            result = 1
            for i in range(1, k + 1):
                result *= i
            cache[k] = result
        return cache[k]

    return compute_factorial(n)
