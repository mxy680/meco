from concurrent.futures import ProcessPoolExecutor, as_completed
from math import prod

def factorial(n: int) -> int:
    if n == 0:
        return 1
    
    def partial_factorial(start, end):
        return prod(range(start, end + 1))

    num_workers = min(32, n)  # reasonable upper limit of workers
    chunk_size = n // num_workers
    futures = []

    with ProcessPoolExecutor(max_workers=num_workers) as executor:
        for i in range(num_workers):
            start = i * chunk_size + 1
            end = (i + 1) * chunk_size if i < num_workers - 1 else n + 1
            futures.append(executor.submit(partial_factorial, start, end))

        result = 1
        for future in as_completed(futures):
            result *= future.result()

    return result
