from joblib import Parallel, delayed

def factorial(n: int) -> int:
    if n < 2:
        return 1

    def multiply_range(start, end):
        result = 1
        for i in range(start, end + 1):
            result *= i
        return result

    num_threads = min(n, 4)  # or any reasonable number of threads you find suitable
    step = n // num_threads
    ranges = [(i * step + 1, (i + 1) * step) for i in range(num_threads)]
    ranges[-1] = (ranges[-1][0], n)  # Adjust the last range to end with n

    partial_results = Parallel(n_jobs=num_threads)(delayed(multiply_range)(start, end) for start, end in ranges)
    total_result = 1
    for partial in partial_results:
        total_result *= partial

    return total_result
