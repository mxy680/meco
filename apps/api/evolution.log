def matrix_multiply(A: list, B: list) -> list:
    def block_multiply(A, B, C, block_size):
        row_A, col_A = len(A), len(A[0])
        col_B = len(B[0])
        for i in range(0, row_A, block_size):
            for j in range(0, col_B, block_size):
                for k in range(0, col_A, block_size):
                    for ii in range(i, min(i + block_size, row_A)):
                        for jj in range(j, min(j + block_size, col_B)):
                            sum = 0
                            for kk in range(k, min(k + block_size, col_A)):
                                sum += A[ii][kk] * B[kk][jj]
                            C[ii][jj] += sum
    
    if not A or not B or len(A[0]) != len(B):
        raise ValueError("Incompatible dimensions for matrix multiplication.")

    row_A, col_B = len(A), len(B[0])
    C = [[0] * col_B for _ in range(row_A)]
    block_size = min(min(row_A, len(B)), 32)
    block_multiply(A, B, C, block_size)
    
    return C

