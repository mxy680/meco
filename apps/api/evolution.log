def factorial(n: int) -> int:
    if n < 0:
        raise ValueError("Factorial is not defined for negative numbers")
    if n == 0 or n == 1:
        return 1

    class FactorialCache:
        def __init__(self, capacity=100):
            self.capacity = capacity
            self.cache = [1] * (capacity + 1)
            self.max_computed = 1

        def get(self, num):
            if num <= self.max_computed:
                return self.cache[num]
            else:
                last_cached = self.max_computed
                result = self.cache[last_cached]
                for i in range(last_cached + 1, num + 1):
                    result *= i
                    self.cache[i % (self.capacity + 1)] = result
                self.max_computed = num
                return result

    cache = FactorialCache()
    return cache.get(n)
