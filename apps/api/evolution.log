def matrix_multiply(A: list, B: list) -> list:
    def block_multiply(A, B, C, block_size):
        n = len(A)
        for i in range(0, n, block_size):
            for j in range(0, n, block_size):
                for k in range(0, n, block_size):
                    for ii in range(i, min(i + block_size, n)):
                        for jj in range(j, min(j + block_size, n)):
                            sum = 0
                            for kk in range(k, min(k + block_size, n)):
                                sum += A[ii][kk] * B[kk][jj]
                            C[ii][jj] += sum
    
    n = len(A)
    C = [[0] * len(B[0]) for _ in range(n)]
    block_size = min(n, 32)
    block_multiply(A, B, C, block_size)
    
    return C
