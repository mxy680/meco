from scipy.sparse import csr_matrix

def matrix_multiply(A: list, B: list) -> list:
    A_sparse = csr_matrix(A)
    B_sparse = csr_matrix(B)
    result_sparse = A_sparse.dot(B_sparse)
    return result_sparse.toarray().tolist()
