def factorial(n: int, memo: dict = None) -> int:
    if n < 0:
        raise ValueError("Negative numbers do not have factorials")
    if memo is None:
        memo = {}
    if n in memo:
        return memo[n]
    if n == 0 or n == 1:
        return 1
    memo[n] = n * factorial(n - 1, memo)
    return memo[n]
