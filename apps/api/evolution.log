import random


def factorial(n: int) -> int:
    if n < 0:
        raise ValueError("Factorial is not defined for negative numbers")
    if n == 0 or n == 1:
        return 1

    def monte_carlo_factorial(num, simulations=10000):
        permutations = list(range(1, num + 1))
        accumulative_sum = 0

        for _ in range(simulations):
            random.shuffle(permutations)
            product = 1
            for value in permutations:
                product *= value
            accumulative_sum += product

        return accumulative_sum // simulations

    return monte_carlo_factorial(n)
