def factorial(n: int) -> int:
    if n < 0:
        raise ValueError("Factorial is not defined for negative numbers")
    if n == 0 or n == 1:
        return 1
    
    def multiply_range(start, end):
        if start > end:
            return 1
        if start == end:
            return start
        if end - start == 1:
            return start * end
        mid = (start + end) // 2
        return multiply_range(start, mid) * multiply_range(mid + 1, end)

    return multiply_range(2, n)
