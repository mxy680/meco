def factorial(n: int) -> int:
    memo = {}
    def recurse(x):
        if x in memo:
            return memo[x]
        if x == 0:
            result = 1
        else:
            result = x * recurse(x - 1)
        memo[x] = result
        return result
    return recurse(n)
