{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".venv/**"], 
      "cache": false
    },
    "install": {
      "dependsOn": ["^install"],
      "inputs": ["$TURBO_DEFAULT$", "pyproject.toml", "poetry.lock"],
      "outputs": ["poetry.lock", "node_modules/**", ".venv/**"]
    }
  }
}
